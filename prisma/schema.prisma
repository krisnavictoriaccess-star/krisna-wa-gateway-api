// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Or mysql, depends on DATABASE_URL
  url      = env("DATABASE_URL")
}

model Package {
  id               Int       @id @default(autoincrement())
  nama_paket       String    @unique
  deskripsi        String?
  harga            String?
  limit_pesan      Int       @default(1000)
  limit_device     Int       @default(1)
  limit_autoreply  Int       @default(5)
  fitur_broadcast  Boolean   @default(false)
  fitur_media      Boolean   @default(false)
  fitur_group      Boolean   @default(false)
  fitur_webhook    Boolean   @default(false)
  fitur_vcard        Boolean   @default(false)
  fitur_lokasi       Boolean   @default(false)
  fitur_polling      Boolean   @default(false)
  fitur_contact_list Boolean   @default(false)
  fitur_group_list   Boolean   @default(false)
  fitur_inbox        Boolean   @default(false)
  is_public        Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ApiKey {
  key              String    @id
  label            String    @default("User")
  status           String    @default("active") // active, revoked, expired
  paket            String    @default("Free")
  limit_pesan      Int       @default(1000)
  max_devices      Int       @default(1)
  terpakai_bulan_ini Int     @default(0)
  last_reset_month String
  expired_at       DateTime
  webhook_url      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  devices          Device[]
  queued_messages  MessageQueue[]
  webhook_queues   WebhookQueue[]
}

model Device {
  id               Int       @id @default(autoincrement())
  nomor_device     String    @unique
  api_key_id       String
  apiKey           ApiKey    @relation(fields: [api_key_id], references: [key], onDelete: Cascade)
  status           String    @default("disconnected") // connected, disconnected
  is_autoread      Boolean   @default(true)
  createdAt        DateTime  @default(now())
  autoReplies      AutoReply[]
  inboxMessages    MessageInbox[]
  authStates       AuthState[]
  contactStores    ContactStore[]
}

model AutoReply {
  id               Int       @id @default(autoincrement())
  keyword          String
  response         String
  match_type       String    @default("exact")
  media_url        String?
  media_type       String?
  nomor_device     String
  device           Device    @relation(fields: [nomor_device], references: [nomor_device], onDelete: Cascade)
  createdAt        DateTime  @default(now())
}

model MessageInbox {
  id               Int       @id @default(autoincrement())
  nomor_device     String
  device           Device    @relation(fields: [nomor_device], references: [nomor_device], onDelete: Cascade)
  sender_jid       String
  message          String
  createdAt        DateTime  @default(now())
  @@index([nomor_device, createdAt])
}

model MessageQueue {
  id               Int       @id @default(autoincrement())
  sender_device    String
  recipient_jid    String
  payload          String // JSON stringified payload (e.g., {text: "hello"} or {image: {url: "..."}})
  status           String    @default("pending") // pending, processing, sent, failed
  error_message    String?
  send_at          DateTime  @default(now())
  api_key_id       String
  apiKey           ApiKey    @relation(fields: [api_key_id], references: [key], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  @@index([status, createdAt])
}

model AuthState {
  id           Int      @id @default(autoincrement())
  nomor_device String
  device       Device   @relation(fields: [nomor_device], references: [nomor_device], onDelete: Cascade)
  key          String
  value        String
  @@unique([nomor_device, key])
}

model ContactStore {
  id           Int      @id @default(autoincrement())
  nomor_device String
  device       Device   @relation(fields: [nomor_device], references: [nomor_device], onDelete: Cascade)
  contact_id   String
  name         String?
  notify       String?
  verifiedName String?
  updatedAt    DateTime @updatedAt
  @@unique([nomor_device, contact_id])
}

model WebhookQueue {
  id           Int      @id @default(autoincrement())
  api_key_id   String
  url          String
  payload      String
  attempts     Int      @default(0)
  status       String   @default("pending") // pending, success, failed
  next_retry   DateTime @default(now())
  createdAt    DateTime @default(now())
  apiKey       ApiKey   @relation(fields: [api_key_id], references: [key], onDelete: Cascade)
  @@index([status, createdAt])
}
